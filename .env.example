# SmartCrack LLM Configuration
# Copy this file to .env and fill in your values

# Provider: gemini, openai, groq, together, openrouter
SMARTCRACK_PROVIDER=gemini

# API key (required for AI-powered knowledge expansion)
SMARTCRACK_API_KEY=

# Or use a custom OpenAI-compatible endpoint instead of a named provider:
# SMARTCRACK_LLM_BASE_URL=https://your-endpoint/v1
# SMARTCRACK_LLM_MODEL=your-model-name
