# HashCrack LLM Configuration
# Copy this file to .env and fill in your values

# LiteLLM / OpenAI-compatible endpoint
SMARTCRACK_LLM_BASE_URL=https://your-llm-endpoint/v1
SMARTCRACK_LLM_MODEL=qwen35b-opus

# API key (required for AI-powered profiling)
SMARTCRACK_LLM_API_KEY=

# Request timeout in seconds (default: 90)
SMARTCRACK_LLM_TIMEOUT=90
